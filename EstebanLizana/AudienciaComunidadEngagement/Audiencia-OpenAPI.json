{
  "openapi": "3.0.3",
  "info": {
    "title": "AudienciaComunidadEngagement API",
    "version": "v1",
    "description": "Gestiona la relación de la audiencia con el contenido y la comunidad: suscripciones, reacciones (like/dislike), comentarios, notificaciones, historial/listas de visualización y publicaciones de comunidad del canal. Referencia channelId, catalogItemId y communityPostId por UUID. No almacena metadata del video ni del canal. Se asume consistencia eventual: los eventos recibidos pueden procesarse con cierto retraso; las visibilidades de contenido se actualizan asíncronamente. La API Key identifica al usuario; todas las operaciones deben validar que el userId del payload coincida con el usuario autenticado."
  },
  "servers": [
    { "url": "http://localhost:5004" }
  ],
  "security": [
    { "ApiKey": [] }
  ],
  "paths": {
    "/api/subscriptions": {
      "post": {
        "tags": ["Subscriptions"],
        "summary": "RF-A1: crea una suscripción (409 si ya existe).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CreateSubscriptionDto" } }
          }
        },
        "responses": {
          "201": { "description": "Creada", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SubscriptionDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": { "$ref": "#/components/responses/Conflict" }
        },
        "x-authorization": "El userId del cuerpo debe coincidir con el usuario autenticado."
      },
      "get": {
        "tags": ["Subscriptions"],
        "summary": "RF-A1: lista suscripciones filtrando por userId/channelId.",
        "parameters": [
          { "name": "userId", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "channelId", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedResultSubscriptionDto" } } } }
        },
        "x-authorization": "Si se filtra por userId, debe coincidir con el usuario autenticado."
      }
    },
    "/api/subscriptions/{id}": {
      "get": {
        "tags": ["Subscriptions"],
        "summary": "RF-A1: obtiene una suscripción por Id.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SubscriptionDto" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "x-authorization": "El usuario autenticado debe ser el propietario de la suscripción."
      },
      "delete": {
        "tags": ["Subscriptions"],
        "summary": "RF-A1: cancela una suscripción.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "responses": {
          "204": { "description": "Sin contenido" },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "x-authorization": "El usuario autenticado debe ser el propietario de la suscripción."
      }
    },
    "/api/subscriptions/count": {
      "get": {
        "tags": ["Subscriptions"],
        "summary": "RF-A1: cantidad de suscriptores de un canal (consumido por Monetización).",
        "parameters": [
          { "name": "channelId", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SubscriberCountDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        },
        "x-authorization": "Acceso permitido a sistemas internos (servicio a servicio)."
      }
    },
    "/api/reactions": {
      "post": {
        "tags": ["Reactions"],
        "summary": "RF-A2: upsert de una reacción (crea o actualiza el Type) sobre un ítem del catálogo.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateReactionDto" } } }
        },
        "responses": {
          "200": { "description": "Actualizada", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReactionDto" } } } },
          "201": { "description": "Creada", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReactionDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        },
        "x-authorization": "El userId del cuerpo debe coincidir con el usuario autenticado."
      },
      "get": {
        "tags": ["Reactions"],
        "summary": "RF-A2: lista reacciones de un item del catálogo.",
        "parameters": [
          { "name": "catalogItemId", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedResultReactionDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/reactions/{id}": {
      "get": {
        "tags": ["Reactions"],
        "summary": "RF-A2: obtiene una reacción por Id.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReactionDto" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "x-authorization": "El usuario autenticado debe ser el propietario de la reacción."
      },
      "delete": {
        "tags": ["Reactions"],
        "summary": "RF-A2: quita una reacción.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "responses": {
          "204": { "description": "Sin contenido" },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "x-authorization": "El usuario autenticado debe ser el propietario de la reacción."
      }
    },
    "/api/reactions/summary": {
      "get": {
        "tags": ["Reactions"],
        "summary": "RF-A2: resumen de likes/dislikes de un item.",
        "parameters": [
          { "name": "catalogItemId", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReactionSummaryDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/comments": {
      "post": {
        "tags": ["Comments"],
        "summary": "RF-A3: crea un comentario o respuesta sobre un ítem del catálogo.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateCommentDto" } } }
        },
        "responses": {
          "201": { "description": "Creado", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CommentDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        },
        "x-authorization": "El userId del cuerpo debe coincidir con el usuario autenticado."
      },
      "get": {
        "tags": ["Comments"],
        "summary": "RF-A3: lista comentarios por catalogItemId y/o parentCommentId.",
        "parameters": [
          { "name": "catalogItemId", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "parentCommentId", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedResultCommentDto" } } } }
        }
      }
    },
    "/api/comments/{id}": {
      "get": {
        "tags": ["Comments"],
        "summary": "RF-A3: obtiene un comentario por Id.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CommentDto" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Comments"],
        "summary": "RF-A3: edita el texto de un comentario.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateCommentDto" } } }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CommentDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "x-authorization": "El usuario autenticado debe ser el autor del comentario."
      },
      "delete": {
        "tags": ["Comments"],
        "summary": "RF-A3: elimina un comentario.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "responses": {
          "204": { "description": "Sin contenido" },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "x-authorization": "El usuario autenticado debe ser el autor del comentario o el creador del contenido asociado."
      }
    },
    "/api/comments/{id}/pin": {
      "post": {
        "tags": ["Comments"],
        "summary": "RF-A3: fija o desfija un comentario destacado (toggle).",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "pinned": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CommentDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "x-authorization": "El usuario autenticado debe ser el creador del contenido (canal) al que pertenece el comentario."
      }
    },
    "/api/comments/{id}/report": {
      "post": {
        "tags": ["Comments"],
        "summary": "RF-A3: reporta un comentario inapropiado.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reason": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Reporte registrado" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "x-authorization": "El usuario autenticado debe ser un usuario registrado."
      }
    },
    "/api/notifications": {
      "post": {
        "tags": ["Notifications"],
        "summary": "RF-A4: crea una notificación (uso interno, normalmente generado por eventos).",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateNotificationDto" } } }
        },
        "responses": {
          "201": { "description": "Creada", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NotificationDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        },
        "x-authorization": "Solo para uso interno (sistemas)."
      },
      "get": {
        "tags": ["Notifications"],
        "summary": "RF-A4: lista notificaciones por userId y/o isRead.",
        "parameters": [
          { "name": "userId", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "isRead", "in": "query", "schema": { "type": "boolean" } },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedResultNotificationDto" } } } }
        },
        "x-authorization": "Si se filtra por userId, debe coincidir con el usuario autenticado."
      }
    },
    "/api/notifications/{id}": {
      "get": {
        "tags": ["Notifications"],
        "summary": "RF-A4: obtiene una notificación por Id.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NotificationDto" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "x-authorization": "El usuario autenticado debe ser el destinatario de la notificación."
      }
    },
    "/api/notifications/{id}/read": {
      "post": {
        "tags": ["Notifications"],
        "summary": "RF-A4: marca una notificación como leída.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NotificationDto" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "x-authorization": "El usuario autenticado debe ser el destinatario de la notificación."
      }
    },
    "/api/notifications/read-all": {
      "post": {
        "tags": ["Notifications"],
        "summary": "RF-A4: marca como leídas todas las notificaciones de un usuario.",
        "parameters": [
          { "name": "userId", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "204": { "description": "Sin contenido" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        },
        "x-authorization": "El userId debe coincidir con el usuario autenticado."
      }
    },
    "/api/notifications/preferences": {
      "get": {
        "tags": ["Notifications"],
        "summary": "RF-A4: obtiene las preferencias de notificación de un usuario.",
        "parameters": [
          { "name": "userId", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NotificationPreferencesDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        },
        "x-authorization": "El userId debe coincidir con el usuario autenticado."
      },
      "put": {
        "tags": ["Notifications"],
        "summary": "RF-A4: actualiza las preferencias de notificación de un usuario.",
        "parameters": [
          { "name": "userId", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateNotificationPreferencesDto" }
            }
          }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NotificationPreferencesDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        },
        "x-authorization": "El userId debe coincidir con el usuario autenticado."
      }
    },
    "/api/history": {
      "post": {
        "tags": ["History"],
        "summary": "RF-A5: registra/actualiza (upsert) la posición de visualización.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RecordWatchDto" } } }
        },
        "responses": {
          "200": { "description": "Actualizada", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WatchHistoryEntryDto" } } } },
          "201": { "description": "Creada", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WatchHistoryEntryDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        },
        "x-authorization": "El userId del cuerpo debe coincidir con el usuario autenticado."
      },
      "get": {
        "tags": ["History"],
        "summary": "RF-A5: lista el historial de un usuario (más reciente primero).",
        "parameters": [
          { "name": "userId", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedResultWatchHistoryEntryDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        },
        "x-authorization": "El userId debe coincidir con el usuario autenticado."
      },
      "delete": {
        "tags": ["History"],
        "summary": "RF-A5: borra todo el historial de un usuario (privacidad).",
        "parameters": [
          { "name": "userId", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "204": { "description": "Sin contenido" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        },
        "x-authorization": "El userId debe coincidir con el usuario autenticado."
      }
    },
    "/api/history/{id}": {
      "get": {
        "tags": ["History"],
        "summary": "RF-A5: obtiene una entrada de historial por Id.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WatchHistoryEntryDto" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "x-authorization": "El usuario autenticado debe ser el propietario de la entrada."
      },
      "delete": {
        "tags": ["History"],
        "summary": "RF-A5: elimina una entrada específica del historial.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "responses": {
          "204": { "description": "Sin contenido" },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "x-authorization": "El usuario autenticado debe ser el propietario de la entrada."
      }
    },
    "/api/watchlater": {
      "post": {
        "tags": ["WatchLater"],
        "summary": "RF-A5: agrega un item a 'ver más tarde' (409 si ya existe).",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateWatchLaterDto" } } }
        },
        "responses": {
          "201": { "description": "Creado", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WatchLaterItemDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": { "$ref": "#/components/responses/Conflict" }
        },
        "x-authorization": "El userId del cuerpo debe coincidir con el usuario autenticado."
      },
      "get": {
        "tags": ["WatchLater"],
        "summary": "RF-A5: lista los items 'ver más tarde' de un usuario.",
        "parameters": [
          { "name": "userId", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedResultWatchLaterItemDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        },
        "x-authorization": "El userId debe coincidir con el usuario autenticado."
      }
    },
    "/api/watchlater/{id}": {
      "get": {
        "tags": ["WatchLater"],
        "summary": "RF-A5: obtiene un item 'ver más tarde' por Id.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WatchLaterItemDto" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "x-authorization": "El usuario autenticado debe ser el propietario del item."
      },
      "delete": {
        "tags": ["WatchLater"],
        "summary": "RF-A5: elimina un item de 'ver más tarde'.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "responses": {
          "204": { "description": "Sin contenido" },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "x-authorization": "El usuario autenticado debe ser el propietario del item."
      }
    },
    "/api/community": {
      "post": {
        "tags": ["Community"],
        "summary": "RF-A6: crea una publicación de comunidad.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateCommunityPostDto" } } }
        },
        "responses": {
          "201": { "description": "Creada", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CommunityPostDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        },
        "x-authorization": "El usuario autenticado debe ser el creador del canal (channelId)."
      },
      "get": {
        "tags": ["Community"],
        "summary": "RF-A6: lista publicaciones de comunidad de un canal (más reciente primero).",
        "parameters": [
          { "name": "channelId", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedResultCommunityPostDto" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/community/{id}": {
      "get": {
        "tags": ["Community"],
        "summary": "RF-A6: obtiene una publicación de comunidad por Id.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CommunityPostDto" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Community"],
        "summary": "RF-A6: elimina una publicación de comunidad.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "responses": {
          "204": { "description": "Sin contenido" },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "x-authorization": "El usuario autenticado debe ser el creador del canal propietario de la publicación."
      }
    },
    "/api/community/{id}/reactions": {
      "post": {
        "tags": ["Community"],
        "summary": "RF-A6: upsert de una reacción a una publicación de comunidad.",
        "parameters": [ { "$ref": "#/components/parameters/Id" } ],
        "requestBody": {
          "required": true,
