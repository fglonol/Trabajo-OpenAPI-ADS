<mxfile host="app.diagrams.net" pages="3">
  <diagram name="D-C" id="-ShRqKNXkcEAc5Ftv_UE">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    %% Enumeraciones\n    class SignalType {\n        &lt;&lt;enumeration&gt;&gt;\n        Impression\n        View\n        Click\n        Like\n        Search\n        WatchTime\n    }\n\n    %% Schemas de datos\n    class IndexedContent {\n        +UUID id\n        +UUID channelId\n        +String title\n        +Double rankingScore\n        +Double trendingScore\n        +Long impressionCount\n        +String visibility\n        +DateTime createdAt\n        +DateTime updatedAt\n        +List~ContentTag~ tags\n    }\n\n    class ContentTag {\n        +UUID id\n        +UUID indexedContentId\n        +String value\n    }\n\n    IndexedContent \&quot;1\&quot; --&gt; \&quot;*\&quot; ContentTag : contains\n\n    class Signal {\n        +UUID id\n        +UUID userId\n        +UUID contentId\n        +SignalType type\n        +Double weight\n        +DateTime createdAt\n    }\n\n    Signal --&gt; SignalType\n\n    class UserInterest {\n        +UUID id\n        +UUID userId\n        +String interest\n        +Double score\n        +DateTime updatedAt\n    }\n\n    %% DTOs de solicitud/respuesta\n    class IndexContentRequest {\n        +UUID id\n        +UUID channelId\n        +String title\n        +String visibility\n        +List~String~ tags\n    }\n\n    class IndexedContentResponse {\n        +UUID id\n        +UUID channelId\n        +String title\n        +Double rankingScore\n        +Double trendingScore\n        +Long impressionCount\n        +String visibility\n        +DateTime createdAt\n        +DateTime updatedAt\n        +List~String~ tags\n    }\n\n    class SignalRequest {\n        +UUID userId\n        +UUID contentId\n        +SignalType type\n        +Double weight\n    }\n\n    SignalRequest --&gt; SignalType\n\n    class SearchResultItem {\n        +UUID contentId\n        +UUID channelId\n        +String title\n        +Double rankingScore\n        +List~String~ tags\n    }\n\n    class FeedItem {\n        +UUID contentId\n        +UUID channelId\n        +String title\n        +Double rankingScore\n        +Double personalizedScore\n        +String reason\n        +List~String~ tags\n    }\n\n    class TrendingItem {\n        +UUID contentId\n        +UUID channelId\n        +String title\n        +Double trendingScore\n        +Long impressionCount\n        +List~String~ tags\n    }\n\n    class ErrorResponse {\n        +String code\n        +String message\n        +Object details\n    }\n\n    %% Envoltorios paginados\n    class PagedResultSearchResultItem {\n        +List~SearchResultItem~ items\n        +Integer page\n        +Integer pageSize\n        +Integer totalItems\n        +Integer totalPages\n    }\n\n    class PagedResultFeedItem {\n        +List~FeedItem~ items\n        +Integer page\n        +Integer pageSize\n        +Integer totalItems\n        +Integer totalPages\n    }\n\n    class PagedResultTrendingItem {\n        +List~TrendingItem~ items\n        +Integer page\n        +Integer pageSize\n        +Integer totalItems\n        +Integer totalPages\n    }\n\n    PagedResultSearchResultItem --&gt; SearchResultItem\n    PagedResultFeedItem --&gt; FeedItem\n    PagedResultTrendingItem --&gt; TrendingItem\n\n    %% Controladores / Servicios (exponen los endpoints)\n    class IndexController {\n        +upsertIndex(request: IndexContentRequest) IndexedContentResponse\n        +getIndexById(id: UUID) IndexedContentResponse\n        +deleteIndex(id: UUID)\n    }\n\n    IndexController ..&gt; IndexContentRequest : uses\n    IndexController ..&gt; IndexedContentResponse : returns\n\n    class SearchController {\n        +search(q: String, type: String, fromDate: Date, toDate: Date, duration: String, sortBy: String, order: String, page: Integer, pageSize: Integer) PagedResultSearchResultItem\n        +getSuggestions(q: String, limit: Integer) List~String~\n    }\n\n    SearchController ..&gt; PagedResultSearchResultItem : returns\n\n    class FeedController {\n        +getFeed(userId: UUID, page: Integer, pageSize: Integer) PagedResultFeedItem\n    }\n\n    FeedController ..&gt; PagedResultFeedItem : returns\n\n    class ContentController {\n        +getRelated(id: UUID, page: Integer, pageSize: Integer) PagedResultSearchResultItem\n    }\n\n    ContentController ..&gt; PagedResultSearchResultItem : returns\n\n    class TrendingController {\n        +getTrending(region: String, categoryId: UUID, page: Integer, pageSize: Integer) PagedResultTrendingItem\n    }\n\n    TrendingController ..&gt; PagedResultTrendingItem : returns\n\n    class ExploreController {\n        +getContentByCategory(categoryId: UUID, page: Integer, pageSize: Integer) PagedResultSearchResultItem\n    }\n\n    ExploreController ..&gt; PagedResultSearchResultItem : returns\n\n    class SignalsController {\n        +captureSignal(request: SignalRequest) Signal\n    }\n\n    SignalsController ..&gt; SignalRequest : uses\n    SignalsController ..&gt; Signal : returns\n\n    %% Relaciones adicionales: IndexedContent se usa en respuestas\n    IndexedContentResponse --|&gt; IndexedContent : extends (similar pero tags como strings)\n    SearchResultItem ..&gt; IndexedContent : derived from\n    FeedItem ..&gt; IndexedContent : derived from\n    TrendingItem ..&gt; IndexedContent : derived from\n\n    %% Señal\n    Signal ..&gt; IndexedContent : references contentId&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="-PL-dzFyImFhKmGT4BaW-189">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
