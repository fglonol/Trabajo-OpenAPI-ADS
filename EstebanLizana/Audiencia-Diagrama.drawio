<mxfile host="app.diagrams.net">
  <diagram name="Página-1" id="hwOEoKmHjaK4GajIZVet">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    %% Enumeraciones\n    class ReactionType {\n        &lt;&lt;enumeration&gt;&gt;\n        Like\n        Dislike\n    }\n\n    %% Entidades principales\n    class Subscription {\n        +UUID id\n        +UUID userId\n        +UUID channelId\n        +DateTime createdAt\n    }\n\n    class Reaction {\n        +UUID id\n        +UUID userId\n        +UUID catalogItemId\n        +ReactionType type\n        +DateTime createdAt\n    }\n\n    Reaction --&gt; ReactionType\n\n    class Comment {\n        +UUID id\n        +UUID userId\n        +UUID catalogItemId\n        +UUID parentCommentId\n        +String text\n        +DateTime createdAt\n        +DateTime editedAt\n        +Boolean pinned\n    }\n\n    Comment \&quot;1\&quot; --&gt; \&quot;0..1\&quot; Comment : parent\n\n    class Notification {\n        +UUID id\n        +UUID userId\n        +String type\n        +String message\n        +Boolean isRead\n        +DateTime createdAt\n    }\n\n    class NotificationPreferences {\n        +UUID userId\n        +Boolean emailNotifications\n        +Boolean pushNotifications\n        +Boolean newVideo\n        +Boolean commentReply\n        +Boolean communityPost\n    }\n\n    class WatchHistoryEntry {\n        +UUID id\n        +UUID userId\n        +UUID catalogItemId\n        +Integer positionSeconds\n        +DateTime watchedAt\n    }\n\n    class WatchLaterItem {\n        +UUID id\n        +UUID userId\n        +UUID catalogItemId\n        +DateTime addedAt\n    }\n\n    class CommunityPost {\n        +UUID id\n        +UUID channelId\n        +String text\n        +DateTime createdAt\n    }\n\n    class CommunityPostReaction {\n        +UUID id\n        +UUID userId\n        +UUID communityPostId\n        +ReactionType type\n        +DateTime createdAt\n    }\n\n    CommunityPostReaction --&gt; ReactionType\n\n    class CommunityPostComment {\n        +UUID id\n        +UUID userId\n        +UUID communityPostId\n        +UUID parentCommentId\n        +String text\n        +DateTime createdAt\n        +DateTime editedAt\n    }\n\n    CommunityPostComment \&quot;1\&quot; --&gt; \&quot;0..1\&quot; CommunityPostComment : parent\n\n    %% DTOs de creación / actualización (opcional, solo para referencia)\n    class CreateSubscriptionDto {\n        +UUID userId\n        +UUID channelId\n    }\n\n    class CreateReactionDto {\n        +UUID userId\n        +UUID catalogItemId\n        +ReactionType type\n    }\n\n    class CreateCommentDto {\n        +UUID userId\n        +UUID catalogItemId\n        +UUID parentCommentId\n        +String text\n    }\n\n    class RecordWatchDto {\n        +UUID userId\n        +UUID catalogItemId\n        +Integer positionSeconds\n    }\n\n    class CreateWatchLaterDto {\n        +UUID userId\n        +UUID catalogItemId\n    }\n\n    class CreateCommunityPostDto {\n        +UUID channelId\n        +String text\n    }\n\n    %% Envoltorios paginados (resumidos)\n    class PagedResult~T~ {\n        +List~T~ items\n        +Integer page\n        +Integer pageSize\n        +Integer totalItems\n        +Integer totalPages\n    }\n\n    %% Controladores\n    class SubscriptionsController {\n        +createSubscription(body: CreateSubscriptionDto) Subscription\n        +listSubscriptions(userId: UUID, channelId: UUID, page, pageSize) PagedResult~Subscription~\n        +getSubscription(id: UUID) Subscription\n        +deleteSubscription(id: UUID)\n        +countSubscribers(channelId: UUID) SubscriberCountDto\n    }\n\n    class ReactionsController {\n        +upsertReaction(body: CreateReactionDto) Reaction\n        +listReactions(catalogItemId: UUID, page, pageSize) PagedResult~Reaction~\n        +getReaction(id: UUID) Reaction\n        +deleteReaction(id: UUID)\n        +getReactionSummary(catalogItemId: UUID) ReactionSummaryDto\n    }\n\n    class CommentsController {\n        +createComment(body: CreateCommentDto) Comment\n        +listComments(catalogItemId: UUID, parentCommentId: UUID, page, pageSize) PagedResult~Comment~\n        +getComment(id: UUID) Comment\n        +updateComment(id: UUID, text: String) Comment\n        +deleteComment(id: UUID)\n        +togglePinComment(id: UUID, pinned: Boolean) Comment\n        +reportComment(id: UUID, reason: String)\n    }\n\n    class NotificationsController {\n        +createNotification(body: CreateNotificationDto) Notification\n        +listNotifications(userId: UUID, isRead: Boolean, page, pageSize) PagedResult~Notification~\n        +getNotification(id: UUID) Notification\n        +markAsRead(id: UUID) Notification\n        +markAllAsRead(userId: UUID)\n        +getPreferences(userId: UUID) NotificationPreferences\n        +updatePreferences(userId: UUID, prefs: UpdateNotificationPreferencesDto) NotificationPreferences\n    }\n\n    class HistoryController {\n        +recordWatch(body: RecordWatchDto) WatchHistoryEntry\n        +listHistory(userId: UUID, page, pageSize) PagedResult~WatchHistoryEntry~\n        +getHistoryEntry(id: UUID) WatchHistoryEntry\n        +deleteHistoryEntry(id: UUID)\n        +clearHistory(userId: UUID)\n    }\n\n    class WatchLaterController {\n        +addToWatchLater(body: CreateWatchLaterDto) WatchLaterItem\n        +listWatchLater(userId: UUID, page, pageSize) PagedResult~WatchLaterItem~\n        +getWatchLaterItem(id: UUID) WatchLaterItem\n        +removeFromWatchLater(id: UUID)\n    }\n\n    class CommunityController {\n        +createCommunityPost(body: CreateCommunityPostDto) CommunityPost\n        +listCommunityPosts(channelId: UUID, page, pageSize) PagedResult~CommunityPost~\n        +getCommunityPost(id: UUID) CommunityPost\n        +deleteCommunityPost(id: UUID)\n        +reactToCommunityPost(postId: UUID, userId: UUID, type: ReactionType) CommunityPostReaction\n        +listCommunityPostReactions(postId: UUID, page, pageSize) PagedResult~CommunityPostReaction~\n        +getCommunityPostReactionSummary(postId: UUID) ReactionSummaryDto\n        +createCommunityPostComment(postId: UUID, userId: UUID, text: String, parentCommentId: UUID) CommunityPostComment\n        +listCommunityPostComments(postId: UUID, parentCommentId: UUID, page, pageSize) PagedResult~CommunityPostComment~\n        +getCommunityPostComment(id: UUID) CommunityPostComment\n        +updateCommunityPostComment(id: UUID, text: String) CommunityPostComment\n        +deleteCommunityPostComment(id: UUID)\n    }\n\n    class IntegrationController {\n        +receiveEvent(event: EventEnvelope)\n    }\n\n    %% Relaciones de uso: controladores usan DTOs y devuelven entidades\n    SubscriptionsController ..&gt; CreateSubscriptionDto : uses\n    SubscriptionsController ..&gt; Subscription : returns\n    ReactionsController ..&gt; CreateReactionDto : uses\n    ReactionsController ..&gt; Reaction : returns\n    CommentsController ..&gt; CreateCommentDto : uses\n    CommentsController ..&gt; Comment : returns\n    HistoryController ..&gt; RecordWatchDto : uses\n    HistoryController ..&gt; WatchHistoryEntry : returns\n    WatchLaterController ..&gt; CreateWatchLaterDto : uses\n    WatchLaterController ..&gt; WatchLaterItem : returns\n    CommunityController ..&gt; CreateCommunityPostDto : uses\n    CommunityController ..&gt; CommunityPost : returns\n    CommunityController ..&gt; CommunityPostReaction : returns\n    CommunityController ..&gt; CommunityPostComment : returns\n    NotificationsController ..&gt; Notification : returns\n    NotificationsController ..&gt; NotificationPreferences : returns\n\n    %% Relaciones entre entidades (referencias conceptuales)\n    Subscription --&gt; \&quot;User\&quot; : userId (reference)\n    Subscription --&gt; \&quot;Channel\&quot; : channelId (reference)\n    Reaction --&gt; \&quot;User\&quot; : userId\n    Reaction --&gt; \&quot;CatalogItem\&quot; : catalogItemId\n    Comment --&gt; \&quot;User\&quot; : userId\n    Comment --&gt; \&quot;CatalogItem\&quot; : catalogItemId\n    Notification --&gt; \&quot;User\&quot; : userId\n    NotificationPreferences --&gt; \&quot;User\&quot; : userId\n    WatchHistoryEntry --&gt; \&quot;User\&quot; : userId\n    WatchHistoryEntry --&gt; \&quot;CatalogItem\&quot; : catalogItemId\n    WatchLaterItem --&gt; \&quot;User\&quot; : userId\n    WatchLaterItem --&gt; \&quot;CatalogItem\&quot; : catalogItemId\n    CommunityPost --&gt; \&quot;Channel\&quot; : channelId\n    CommunityPostReaction --&gt; \&quot;User\&quot; : userId\n    CommunityPostReaction --&gt; CommunityPost : communityPostId\n    CommunityPostComment --&gt; \&quot;User\&quot; : userId\n    CommunityPostComment --&gt; CommunityPost : communityPostId&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="nM6FQRL9ntAjmwXPsFUV-57">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
