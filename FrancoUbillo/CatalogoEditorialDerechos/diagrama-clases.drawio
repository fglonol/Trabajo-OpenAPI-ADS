        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    class Channel {\n        +Guid Id\n        +string Name\n        +string? Description\n        +Guid OwnerUserId\n        +DateTime CreatedAt\n    }\n\n    class CatalogItem {\n        +Guid Id\n        +Guid VideoAssetId\n        +Guid ChannelId\n        +string Title\n        +string? Description\n        +string? ThumbnailUrl\n        +Visibility Visibility\n        +int MinAge\n        +DateTime CreatedAt\n        +DateTime UpdatedAt\n        +List~string~ Tags\n        +List~CountryRestrictionDto~ CountryRestrictions\n        +List~PolicyHistoryEntry~ PolicyHistory\n    }\n\n    class CountryRestriction {\n        +string CountryCode\n        +RestrictionType Type\n    }\n\n    class Playlist {\n        +Guid Id\n        +Guid ChannelId\n        +string Title\n        +Visibility Visibility\n        +DateTime CreatedAt\n        +List~PlaylistItemResponseDto~ Items\n    }\n\n    class PlaylistItem {\n        +Guid Id\n        +Guid PlaylistId\n        +Guid CatalogItemId\n        +int Position\n    }\n\n    class Claim {\n        +Guid Id\n        +Guid CatalogItemId\n        +string ClaimantName\n        +string Reason\n        +ClaimStatus Status\n        +DateTime CreatedAt\n        +DateTime? ResolvedAt\n    }\n\n    class VisibilityCheckResponse {\n        +bool Visible\n        +VisibilityReason? Reason\n    }\n\n    class PolicyHistoryEntry {\n        +DateTime ChangedAt\n        +string Field\n        +object? OldValue\n        +object? NewValue\n    }\n\n    class Visibility {\n        &lt;&lt;enumeration&gt;&gt;\n        Draft\n        Public\n        Unlisted\n        Private\n    }\n\n    class RestrictionType {\n        &lt;&lt;enumeration&gt;&gt;\n        Allow\n        Block\n    }\n\n    class ClaimStatus {\n        &lt;&lt;enumeration&gt;&gt;\n        Pending\n        Resolved\n        Rejected\n    }\n\n    class VisibilityReason {\n        &lt;&lt;enumeration&gt;&gt;\n        AGE_RESTRICTED\n        COUNTRY_BLOCKED\n        MODERATION_PENDING\n        UNLISTED\n        PRIVATE\n        CLAIM_RESTRICTED\n    }\n\n    class ErrorResponse {\n        +string Code\n        +string Message\n        +object? Details\n    }\n\n    class PagedResult~T~ {\n        +List~T~ Items\n        +int Page\n        +int PageSize\n        +int TotalItems\n        +int TotalPages\n    }\n\n    Channel \&quot;1\&quot; --&gt; \&quot;0..*\&quot; CatalogItem : ChannelId\n    Channel \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Playlist : ChannelId\n    CatalogItem \&quot;1\&quot; *-- \&quot;0..*\&quot; CountryRestriction : CountryRestrictions\n    CatalogItem \&quot;1\&quot; *-- \&quot;0..*\&quot; string : Tags\n    CatalogItem \&quot;1\&quot; *-- \&quot;0..*\&quot; PolicyHistoryEntry : PolicyHistory\n    Playlist \&quot;1\&quot; *-- \&quot;0..*\&quot; PlaylistItem : Items\n    PlaylistItem \&quot;0..*\&quot; ..&gt; \&quot;1\&quot; CatalogItem : CatalogItemId (ref)\n    Claim \&quot;0..*\&quot; ..&gt; \&quot;1\&quot; CatalogItem : CatalogItemId (ref)\n    CatalogItem ..&gt; Visibility\n    Playlist ..&gt; Visibility\n    CountryRestriction ..&gt; RestrictionType\n    Claim ..&gt; ClaimStatus\n    VisibilityCheckResponse ..&gt; VisibilityReason\n    CatalogItem ..&gt; VisibilityCheckResponse : genera\n    PagedResult~T~ ..&gt; Channel : T = ChannelResponseDto\n    PagedResult~T~ ..&gt; CatalogItem : T = CatalogItemResponseDto\n    PagedResult~T~ ..&gt; Playlist : T = PlaylistResponseDto\n    PagedResult~T~ ..&gt; Claim : T = ClaimResponseDto&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="OYXFGqokBYKxYxqlgF3q-1">
