{
  "openapi": "3.0.3",
  "info": {
    "title": "PublicacionDistribucion API",
    "version": "1.0.0",
    "description": "Gestiona el ciclo de vida técnico del contenido: subida, procesamiento (transcodificación), reproducción, transmisión en vivo y consulta de assets técnicos. NO almacena metadata editorial (título, descripción, tags); eso pertenece a Catálogo."
  },
  "servers": [
    {
      "url": "http://localhost:5001",
      "description": "Entorno local de desarrollo"
    }
  ],
  "security": [
    {
      "ApiKey": []
    }
  ],
  "tags": [
    {
      "name": "VideoAssets",
      "description": "Assets técnicos de video (RF-P1 a RF-P5)"
    }
  ],
  "paths": {
    "/api/videoassets": {
      "get": {
        "tags": ["VideoAssets"],
        "summary": "RF-P5: lista paginada de assets técnicos",
        "operationId": "listVideoAssets",
        "parameters": [
          { "$ref": "#/components/parameters/PageParam" },
          { "$ref": "#/components/parameters/PageSizeParam" },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "Filtro opcional por estado técnico.",
            "schema": { "$ref": "#/components/schemas/VideoStatus" }
          }
        ],
        "responses": {
          "200": {
            "description": "Listado paginado de assets.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PagedResultVideoAssetResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["VideoAssets"],
        "summary": "RF-P1: registra una nueva subida de video",
        "operationId": "createUpload",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateUploadRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Asset creado con Status=Uploaded.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoAssetResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/videoassets/{id}": {
      "get": {
        "tags": ["VideoAssets"],
        "summary": "RF-P5: obtiene un asset técnico individual",
        "operationId": "getVideoAssetById",
        "parameters": [
          { "$ref": "#/components/parameters/IdParam" }
        ],
        "responses": {
          "200": {
            "description": "Asset técnico encontrado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoAssetResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
        "/api/videoassets/{id}/upload": {
      "delete": {
        "tags": ["VideoAssets"],
        "summary": "RF-P1: Cancela una subida en curso",
        "parameters": [
          { "$ref": "#/components/parameters/IdParam" }
        ],
        "responses": {
          "204": { "description": "Subida cancelada exitosamente." },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": {
            "description": "No se puede cancelar porque el asset ya está procesando o ya fue procesado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/videoassets/{id}/upload-progress": {
      "get": {
        "tags": ["VideoAssets"],
        "summary": "RF-P1: Consulta el progreso de la subida (porcentaje o bytes subidos)",
        "parameters": [
          { "$ref": "#/components/parameters/IdParam" }
        ],
        "responses": {
          "200": {
            "description": "Progreso de la subida.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UploadProgressResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/videoassets/{id}/retry-process": {
      "post": {
        "tags": ["VideoAssets"],
        "summary": "RF-P2: Reintenta el procesamiento de un asset que falló",
        "parameters": [
          { "$ref": "#/components/parameters/IdParam" }
        ],
        "responses": {
          "202": {
            "description": "Reintento de procesamiento aceptado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoAssetResponse" }
              }
            }
          },
          "400": {
            "description": "El asset no está en estado Failed, no se puede reintentar.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/playback-sessions": {
      "post": {
        "tags": ["Playback"],
        "summary": "RF-P3: Inicia una sesión de reproducción",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePlaybackSessionRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Sesión iniciada.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlaybackSessionResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/playback-sessions/{sessionId}": {
      "patch": {
        "tags": ["Playback"],
        "summary": "RF-P3: Actualiza el progreso o finaliza la sesión de reproducción (envía métricas)",
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdatePlaybackProgressRequest" }
            }
          }
        },
        "responses": {
          "204": { "description": "Progreso actualizado correctamente." },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "description": "Sesión no encontrada." }
        }
      }
    },
    "/api/videoassets/{id}/process": {
      "post": {
        "tags": ["VideoAssets"],
        "summary": "RF-P2: simula la transcodificación y genera las calidades",
        "operationId": "processVideoAsset",
        "parameters": [
          { "$ref": "#/components/parameters/IdParam" }
        ],
        "responses": {
          "200": {
            "description": "Asset procesado (Status=Ready) con sus calidades.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoAssetResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/videoassets/{id}/playback": {
      "get": {
        "tags": ["VideoAssets"],
        "summary": "RF-P3: información de reproducción del asset",
        "operationId": "getPlayback",
        "parameters": [
          { "$ref": "#/components/parameters/IdParam" }
        ],
        "responses": {
          "200": {
            "description": "Información de reproducción.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlaybackResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": {
            "description": "El asset aún no está disponible para reproducción.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/videoassets/live": {
      "post": {
        "tags": ["VideoAssets"],
        "summary": "RF-P4: crea una transmisión en vivo",
        "operationId": "createLive",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateLiveRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Asset en vivo creado (Status=Live, IsLive=true).",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoAssetResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/videoassets/{id}/live/stop": {
      "post": {
        "tags": ["VideoAssets"],
        "summary": "RF-P4: finaliza una transmisión en vivo",
        "operationId": "stopLive",
        "parameters": [
          { "$ref": "#/components/parameters/IdParam" }
        ],
        "responses": {
          "200": {
            "description": "Transmisión finalizada (Status=LiveEnded, IsLive=false).",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoAssetResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API Key requerida en el header X-API-Key."
      }
    },
    "parameters": {
      "IdParam": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "Identificador único del asset (UUID).",
        "schema": { "type": "string", "format": "uuid" }
      },
      "PageParam": {
        "name": "page",
        "in": "query",
        "required": false,
        "description": "Número de página (inicia en 1).",
        "schema": { "type": "integer", "format": "int32", "minimum": 1, "default": 1 }
      },
      "PageSizeParam": {
        "name": "pageSize",
        "in": "query",
        "required": false,
        "description": "Tamaño de página (máximo 100).",
        "schema": { "type": "integer", "format": "int32", "minimum": 1, "maximum": 100, "default": 20 }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Solicitud inválida.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "API Key faltante o inválida.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "NotFound": {
        "description": "Recurso no encontrado.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
            "UploadProgressResponse": {
        "type": "object",
        "properties": {
          "videoAssetId": { "type": "string", "format": "uuid" },
          "status": { "type": "string", "enum": ["Uploading", "Uploaded", "Processing", "Ready", "Failed"] },
          "bytesUploaded": { "type": "integer", "format": "int64" },
          "totalBytes": { "type": "integer", "format": "int64" },
          "percentage": { "type": "number", "format": "float" }
        }
      },
      "CreatePlaybackSessionRequest": {
        "type": "object",
        "required": ["videoAssetId", "userId"],
        "properties": {
          "videoAssetId": { "type": "string", "format": "uuid" },
          "userId": { "type": "string", "format": "uuid" },
          "device": { "type": "string" },
          "region": { "type": "string" }
        }
      },
      "PlaybackSessionResponse": {
        "type": "object",
        "properties": {
          "sessionId": { "type": "string", "format": "uuid" },
          "videoAssetId": { "type": "string", "format": "uuid" },
          "userId": { "type": "string", "format": "uuid" },
          "startedAt": { "type": "string", "format": "date-time" },
          "device": { "type": "string" },
          "region": { "type": "string" }
        }
      },
      "UpdatePlaybackProgressRequest": {
        "type": "object",
        "properties": {
          "watchTimeSeconds": { "type": "number" },
          "qualityUsed": { "type": "string" },
          "interruptions": { "type": "integer" },
          "ended": { "type": "boolean" }
        }
      },
      "VideoStatus": {
        "type": "string",
        "description": "Estado técnico del asset de video.",
        "enum": ["Uploaded", "Processing", "Ready", "Failed", "Live", "LiveEnded"]
      },
      "CreateUploadRequest": {
        "type": "object",
        "required": ["originalFileName"],
        "properties": {
          "originalFileName": {
            "type": "string",
            "description": "Nombre del archivo original a subir."
          }
        }
      },
      "CreateLiveRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "nullable": true,
            "description": "Etiqueta opcional de la sesión en vivo (no editorial)."
          }
        }
      },
      "VideoQualityResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "label": { "type": "string", "example": "720p" },
          "width": { "type": "integer", "format": "int32" },
          "height": { "type": "integer", "format": "int32" },
          "bitrateKbps": { "type": "integer", "format": "int32" }
        }
      },
      "VideoAssetResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "originalFileName": { "type": "string" },
          "status": { "$ref": "#/components/schemas/VideoStatus" },
          "durationSeconds": { "type": "integer", "format": "int32" },
          "isLive": { "type": "boolean" },
          "streamingUrl": { "type": "string", "nullable": true },
          "thumbnailUrl": { "type": "string", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "qualities": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/VideoQualityResponse" }
          }
        }
      },
      "PlaybackResponse": {
        "type": "object",
        "properties": {
          "videoAssetId": { "type": "string", "format": "uuid" },
          "status": { "$ref": "#/components/schemas/VideoStatus" },
          "streamingUrl": { "type": "string", "nullable": true },
          "durationSeconds": { "type": "integer", "format": "int32" },
          "isLive": { "type": "boolean" },
          "qualities": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/VideoQualityResponse" }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "example": "NOT_FOUND" },
          "message": { "type": "string", "example": "Recurso no encontrado." },
          "details": { "type": "object", "nullable": true }
        }
      },
      "PagedResultVideoAssetResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/VideoAssetResponse" }
          },
          "page": { "type": "integer", "format": "int32" },
          "pageSize": { "type": "integer", "format": "int32" },
          "totalItems": { "type": "integer", "format": "int32" },
          "totalPages": { "type": "integer", "format": "int32" }
        }
      }
    }
  }
}
