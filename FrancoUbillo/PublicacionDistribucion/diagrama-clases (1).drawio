        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    class VideoAsset {\n        +Guid Id\n        +string OriginalFileName\n        +VideoStatus Status\n        +int DurationSeconds\n        +bool IsLive\n        +string? StreamingUrl\n        +string? ThumbnailUrl\n        +DateTime CreatedAt\n        +DateTime UpdatedAt\n        +List~VideoQualityResponse~ Qualities\n        +List~PlaybackSession~ PlaybackSessions\n    }\n\n    class VideoQuality {\n        +Guid Id\n        +Guid VideoAssetId\n        +string Label\n        +int Width\n        +int Height\n        +int BitrateKbps\n        +VideoAsset? VideoAsset\n    }\n\n    class PlaybackSession {\n        +Guid SessionId\n        +Guid VideoAssetId\n        +Guid UserId\n        +DateTime StartedAt\n        +string Device\n        +string Region\n        +float? WatchTimeSeconds\n        +string? QualityUsed\n        +int? Interruptions\n        +bool? Ended\n    }\n\n    class UploadProgress {\n        +Guid VideoAssetId\n        +UploadStatus Status\n        +long BytesUploaded\n        +long TotalBytes\n        +float Percentage\n    }\n\n    class VideoStatus {\n        &lt;&lt;enumeration&gt;&gt;\n        Uploaded\n        Processing\n        Ready\n        Failed\n        Live\n        LiveEnded\n    }\n\n    class UploadStatus {\n        &lt;&lt;enumeration&gt;&gt;\n        Uploading\n        Uploaded\n        Processing\n        Ready\n        Failed\n    }\n\n    class CreateUploadRequest {\n        +string OriginalFileName\n    }\n\n    class CreateLiveRequest {\n        +string? Title\n    }\n\n    class PlaybackResponse {\n        +Guid VideoAssetId\n        +VideoStatus Status\n        +string? StreamingUrl\n        +int DurationSeconds\n        +bool IsLive\n        +List~VideoQualityResponse~ Qualities\n    }\n\n    class CreatePlaybackSessionRequest {\n        +Guid VideoAssetId\n        +Guid UserId\n        +string Device\n        +string Region\n    }\n\n    class PlaybackSessionResponse {\n        +Guid SessionId\n        +Guid VideoAssetId\n        +Guid UserId\n        +DateTime StartedAt\n        +string Device\n        +string Region\n    }\n\n    class UpdatePlaybackProgressRequest {\n        +float WatchTimeSeconds\n        +string QualityUsed\n        +int Interruptions\n        +bool Ended\n    }\n\n    class ErrorResponse {\n        +string Code\n        +string Message\n        +object? Details\n    }\n\n    class PagedResultVideoAssetResponse {\n        +List~VideoAssetResponse~ Items\n        +int Page\n        +int PageSize\n        +int TotalItems\n        +int TotalPages\n    }\n\n    VideoAsset \&quot;1\&quot; *-- \&quot;0..*\&quot; VideoQuality : Qualities (cascade delete)\n    VideoAsset \&quot;1\&quot; *-- \&quot;0..*\&quot; PlaybackSession : PlaybackSessions\n    VideoAsset --&gt; VideoStatus : Status\n    VideoQuality --&gt; VideoAsset : VideoAsset (ref)\n    PlaybackSession --&gt; VideoAsset : VideoAsset (ref)\n    PlaybackSession --&gt; UploadStatus : Status\n    UploadProgress --&gt; VideoAsset : VideoAsset (ref)\n    UploadProgress --&gt; UploadStatus : Status\n    PlaybackResponse --&gt; VideoStatus : Status\n    PlaybackResponse \&quot;1\&quot; *-- \&quot;0..*\&quot; VideoQuality : Qualities\n    PlaybackSessionResponse --&gt; PlaybackSession : genera\n    CreatePlaybackSessionRequest ..&gt; PlaybackSession : crea\n    UpdatePlaybackProgressRequest ..&gt; PlaybackSession : actualiza\n    CreateUploadRequest ..&gt; VideoAsset : crea\n    CreateLiveRequest ..&gt; VideoAsset : crea\n    VideoAsset ..&gt; PlaybackResponse : genera\n    VideoAsset ..&gt; UploadProgress : genera\n    PagedResultVideoAssetResponse \&quot;1\&quot; *-- \&quot;0..*\&quot; VideoAsset : Items&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="OYXFGqokBYKxYxqlgF3q-128">
