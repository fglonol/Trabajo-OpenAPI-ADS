        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    class VideoAsset {\n        +Guid Id\n        +string OriginalFileName\n        +VideoStatus Status\n        +int DurationSeconds\n        +bool IsLive\n        +string? StreamingUrl\n        +string? ThumbnailUrl\n        +DateTime CreatedAt\n        +DateTime UpdatedAt\n        +List~VideoQualityResponse~ Qualities\n    }\n\n    class VideoQuality {\n        +Guid Id\n        +Guid VideoAssetId\n        +string Label\n        +int Width\n        +int Height\n        +int BitrateKbps\n        +VideoAsset? VideoAsset\n    }\n\n    class VideoStatus {\n        &lt;&lt;enumeration&gt;&gt;\n        Uploaded\n        Processing\n        Ready\n        Failed\n        Live\n        LiveEnded\n    }\n\n    class CreateUploadRequest {\n        +string OriginalFileName\n    }\n\n    class CreateLiveRequest {\n        +string? Title\n    }\n\n    class PlaybackResponse {\n        +Guid VideoAssetId\n        +VideoStatus Status\n        +string? StreamingUrl\n        +int DurationSeconds\n        +bool IsLive\n        +List~VideoQualityResponse~ Qualities\n    }\n\n    class ErrorResponse {\n        +string Code\n        +string Message\n        +object? Details\n    }\n\n    class PagedResultVideoAssetResponse {\n        +List~VideoAssetResponse~ Items\n        +int Page\n        +int PageSize\n        +int TotalItems\n        +int TotalPages\n    }\n\n    VideoAsset \&quot;1\&quot; *-- \&quot;0..*\&quot; VideoQuality : Qualities (cascade delete)\n    VideoAsset --&gt; VideoStatus : Status\n    VideoQuality --&gt; VideoAsset : VideoAsset (ref)\n    PlaybackResponse --&gt; VideoStatus : Status\n    PlaybackResponse \&quot;1\&quot; *-- \&quot;0..*\&quot; VideoQuality : Qualities\n    PagedResultVideoAssetResponse \&quot;1\&quot; *-- \&quot;0..*\&quot; VideoAsset : Items\n    CreateUploadRequest ..&gt; VideoAsset : crea\n    CreateLiveRequest ..&gt; VideoAsset : crea\n    VideoAsset ..&gt; PlaybackResponse : genera&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="wl-CBl9rBJJembXeMl92-104">
