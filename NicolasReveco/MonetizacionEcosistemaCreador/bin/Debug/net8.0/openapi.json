{
  "openapi": "3.0.3",
  "info": {
    "title": "MonetizacionEcosistemaCreador API",
    "version": "1.0.0",
    "description": "Gestiona la monetización del ecosistema de creadores: elegibilidad, productos, ingresos, ganancias y pagos."
  },
  "servers": [
    { "url": "http://localhost:5005" }
  ],
  "security": [
    { "ApiKey": [] }
  ],
  "paths": {
    "/api/eligibility/evaluate": {
      "post": {
        "tags": ["Eligibility"],
        "summary": "RF-M1: Evalúa la elegibilidad de un canal (upsert).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EvaluateEligibilityRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resultado de la evaluación.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EligibilityResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/eligibility/{channelId}": {
      "get": {
        "tags": ["Eligibility"],
        "summary": "RF-M1: Obtiene la elegibilidad de un canal.",
        "parameters": [
          {
            "name": "channelId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Resultado de elegibilidad.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EligibilityResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/monetization/applications": {
      "post": {
        "tags": ["Eligibility"],
        "summary": "RF-M1: Permite que un creador solicite monetizar su canal.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateMonetizationApplicationRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Solicitud de monetización creada en estado pendiente.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MonetizationApplicationResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/api/monetization/channels/{channelId}/status": {
      "put": {
        "tags": ["Eligibility"],
        "summary": "RF-M1: Activa o desactiva la monetización a nivel de canal.",
        "parameters": [
          {
            "name": "channelId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateMonetizationStatusRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Estado de monetización actualizado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MonetizationStatusResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/monetization/content/{catalogItemId}/status": {
      "put": {
        "tags": ["Eligibility"],
        "summary": "RF-M1: Activa o desactiva la monetización para un contenido específico.",
        "parameters": [
          {
            "name": "catalogItemId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateMonetizationStatusRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Estado de monetización del contenido actualizado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MonetizationStatusResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/products": {
      "post": {
        "tags": ["Products"],
        "summary": "RF-M2: Crea un producto de monetización.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateProductRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Producto creado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProductResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "get": {
        "tags": ["Products"],
        "summary": "RF-M2: Lista paginada de productos de un canal.",
        "parameters": [
          {
            "name": "channelId",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": {
            "description": "Página de productos.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PagedResultProductResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/products/{id}": {
      "get": {
        "tags": ["Products"],
        "summary": "RF-M2: Obtiene un producto por Id.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Producto.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProductResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Products"],
        "summary": "RF-M2: Actualiza un producto.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateProductRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Producto actualizado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProductResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Products"],
        "summary": "RF-M2: Elimina un producto.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "204": { "description": "Producto eliminado." },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/products/purchases": {
      "post": {
        "tags": ["Products"],
        "summary": "RF-M2: Registra la compra de una membresía o propina de un espectador.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateProductPurchaseRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Compra registrada y disponible para originar ingresos del creador.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProductPurchaseResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/revenue": {
      "post": {
        "tags": ["Revenue"],
        "summary": "RF-M3: Registra un ingreso con estado y reglas de reparto.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateRevenueRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Ingreso registrado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RevenueResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "get": {
        "tags": ["Revenue"],
        "summary": "RF-M3: Lista paginada de ingresos de un canal.",
        "parameters": [
          {
            "name": "channelId",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "source",
            "in": "query",
            "required": false,
            "schema": { "$ref": "#/components/schemas/RevenueSource" }
          },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": {
            "description": "Página de ingresos.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PagedResultRevenueResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/earnings/{channelId}": {
      "get": {
        "tags": ["Earnings"],
        "summary": "RF-M4: Obtiene ganancias por periodo y desglose por origen/video.",
        "parameters": [
          {
            "name": "channelId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "from",
            "in": "query",
            "required": false,
            "description": "Fecha inicial del periodo a consultar.",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "to",
            "in": "query",
            "required": false,
            "description": "Fecha final del periodo a consultar.",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "groupBy",
            "in": "query",
            "required": false,
            "description": "Agrupación del reporte de ganancias.",
            "schema": { "type": "string", "enum": ["source", "video", "day", "month"], "default": "source" }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "description": "Formato de salida para reportes exportables.",
            "schema": { "type": "string", "enum": ["json", "csv"], "default": "json" }
          }
        ],
        "responses": {
          "200": {
            "description": "Ganancias del canal.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EarningsResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/fiscal-documents": {
      "post": {
        "tags": ["Payouts"],
        "summary": "RF-M5: Registra documentación fiscal requerida para cobrar.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateFiscalDocumentRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Documento fiscal registrado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FiscalDocumentResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "get": {
        "tags": ["Payouts"],
        "summary": "RF-M5: Lista documentación fiscal de un canal.",
        "parameters": [
          {
            "name": "channelId",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": {
            "description": "Página de documentos fiscales.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PagedResultFiscalDocumentResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/payouts": {
      "post": {
        "tags": ["Payouts"],
        "summary": "RF-M5: Solicita un payout si supera el mínimo y descuenta el saldo.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePayoutRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Payout creado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PayoutResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      },
      "get": {
        "tags": ["Payouts"],
        "summary": "RF-M5: Lista paginada de pagos de un canal.",
        "parameters": [
          {
            "name": "channelId",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": { "$ref": "#/components/schemas/PayoutStatus" }
          },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": {
            "description": "Página de pagos.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PagedResultPayoutResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/payouts/{id}/complete": {
      "post": {
        "tags": ["Payouts"],
        "summary": "RF-M5: Marca un payout como pagado.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Payout pagado.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PayoutResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/api/payouts/{id}/fail": {
      "post": {
        "tags": ["Payouts"],
        "summary": "RF-M5: Marca un payout como fallido y reintegra el monto.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Payout fallido (monto reintegrado).",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PayoutResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API Key requerida en el header X-API-Key."
      }
    },
    "parameters": {
      "Page": {
        "name": "page",
        "in": "query",
        "required": false,
        "schema": { "type": "integer", "minimum": 1, "default": 1 }
      },
      "PageSize": {
        "name": "pageSize",
        "in": "query",
        "required": false,
        "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Solicitud inválida.",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
        }
      },
      "Unauthorized": {
        "description": "API Key faltante o inválida.",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
        }
      },
      "NotFound": {
        "description": "Recurso no encontrado.",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
        }
      },
      "Conflict": {
        "description": "Conflicto con el estado actual del recurso.",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
        }
      }
    },
    "schemas": {
      "EligibilityStatus": {
        "type": "string",
        "enum": ["NotEvaluated", "UnderReview", "Eligible", "Rejected"]
      },
      "ProductType": {
        "type": "string",
        "enum": ["Membership", "SuperThanks", "Ads"]
      },
      "RevenueSource": {
        "type": "string",
        "enum": ["Ads", "Membership", "Tip"]
      },
      "RevenueStatus": {
        "type": "string",
        "description": "Estado contable del ingreso hasta que queda disponible para payout.",
        "enum": ["Pending", "Confirmed", "Paid"]
      },
      "PayoutStatus": {
        "type": "string",
        "enum": ["Pending", "Paid", "Failed"]
      },
      "FiscalDocumentStatus": {
        "type": "string",
        "enum": ["PendingReview", "Approved", "Rejected"]
      },
      "CreatorEarnings": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "channelId": { "type": "string", "format": "uuid" },
          "creatorUserId": { "type": "string", "format": "uuid" },
          "balance": { "type": "number", "format": "double" },
          "currency": { "type": "string" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "MonetizationEligibility": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "channelId": { "type": "string", "format": "uuid" },
          "subscriberCount": { "type": "integer" },
          "watchHours": { "type": "number", "format": "double" },
          "isEligible": { "type": "boolean" },
          "status": { "$ref": "#/components/schemas/EligibilityStatus" },
          "evaluatedAt": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "MonetizationProduct": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "channelId": { "type": "string", "format": "uuid" },
          "type": { "$ref": "#/components/schemas/ProductType" },
          "name": { "type": "string" },
          "price": { "type": "number", "format": "double" },
          "isActive": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "RevenueEntry": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "channelId": { "type": "string", "format": "uuid" },
          "videoId": { "type": "string", "format": "uuid", "nullable": true },
          "source": { "$ref": "#/components/schemas/RevenueSource" },
          "amount": { "type": "number", "format": "double" },
          "platformShare": { "type": "number", "format": "double", "description": "Monto retenido por la plataforma según regla de reparto." },
          "creatorShare": { "type": "number", "format": "double", "description": "Monto atribuido al creador según regla de reparto." },
          "status": { "$ref": "#/components/schemas/RevenueStatus" },
          "occurredAt": { "type": "string", "format": "date-time" }
        }
      },
      "Payout": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "channelId": { "type": "string", "format": "uuid" },
          "amount": { "type": "number", "format": "double" },
          "status": { "$ref": "#/components/schemas/PayoutStatus" },
          "requestedAt": { "type": "string", "format": "date-time" },
          "paidAt": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "CreateMonetizationApplicationRequest": {
        "type": "object",
        "required": ["channelId", "creatorUserId"],
        "properties": {
          "channelId": { "type": "string", "format": "uuid" },
          "creatorUserId": { "type": "string", "format": "uuid" },
          "notes": { "type": "string", "nullable": true }
        }
      },
      "MonetizationApplicationResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "channelId": { "type": "string", "format": "uuid" },
          "creatorUserId": { "type": "string", "format": "uuid" },
          "status": { "$ref": "#/components/schemas/EligibilityStatus" },
          "requestedAt": { "type": "string", "format": "date-time" },
          "reviewedAt": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "UpdateMonetizationStatusRequest": {
        "type": "object",
        "required": ["enabled"],
        "properties": {
          "enabled": { "type": "boolean" },
          "reason": { "type": "string", "nullable": true }
        }
      },
      "MonetizationStatusResponse": {
        "type": "object",
        "properties": {
          "resourceId": { "type": "string", "format": "uuid" },
